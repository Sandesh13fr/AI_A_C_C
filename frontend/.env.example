# =============================================================================
# Frontend Environment Configuration — aw-compliance-intelligence-db
# Copy this file to .env.local and fill in your values.
#   cp frontend/.env.example frontend/.env.local
#
# Next.js automatically loads .env.local and exposes vars prefixed with
# NEXT_PUBLIC_ to the browser.
# =============================================================================

# ── API ────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# ── Auth (Supabase / Neon Auth) ────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Neon Auth URL — set after provisioning Neon Auth on the branch
NEXT_PUBLIC_AUTH_BASE_URL=

# ── Branding ───────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_NAME=OpenPaws
NEXT_PUBLIC_APP_TAGLINE=Animal Welfare Compliance Intelligence

# ── Sentry (client-side) ───────────────────────────────────────────────────

NEXT_PUBLIC_SENTRY_DSN=

# # ── Feature Flags ──────────────────────────────────────────────────────────

# # Mirrors backend feature flags so the UI can show/hide routes and actions.
# NEXT_PUBLIC_FEATURE_CONTRACT_ANALYSIS=false
# NEXT_PUBLIC_FEATURE_GAP_ANALYSIS=false
# NEXT_PUBLIC_FEATURE_RULEBOOKS=false
# NEXT_PUBLIC_FEATURE_WATCHLISTS=false
